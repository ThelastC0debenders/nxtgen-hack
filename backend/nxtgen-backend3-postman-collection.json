{
  "info": {
    "name": "NxtGen Hack - Backend 3",
    "description": "API collection for testing the Backend 3 refactored architecture (Invoices, Audit, Admin). Note: Replace {{token}} in authorization with a valid JWT for the respective role.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Service Up Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/health",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "health"
              ]
            },
            "description": "Public endpoint to verify the service is running."
          }
        }
      ]
    },
    {
      "name": "Invoices",
      "item": [
        {
          "name": "1. Upload Invoice (VENDOR)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{vendor_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"invoiceNumber\": \"INV-001\",\n  \"sellerGSTIN\": \"29aabcu9603r1zm\",\n  \"buyerGSTIN\": \"27aaacm5748q1zp\",\n  \"invoiceDate\": \"2026-02-21\",\n  \"invoiceAmount\": 15000,\n  \"irn\": \"abc123\",\n  \"irnStatus\": \"VALID\",\n  \"lineItems\": [\n    { \"description\": \"Widget A\", \"sku\": \"WA-01\", \"quantity\": 10, \"unitPrice\": 1500, \"total\": 15000 }\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/invoices/upload",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "invoices",
                "upload"
              ]
            }
          }
        },
        {
          "name": "2. Verify Invoice (ADMIN/LENDER)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"invoiceNumber\": \"INV-001\",\n  \"sellerGSTIN\": \"29aabcu9603r1zm\",\n  \"buyerGSTIN\": \"27aaacm5748q1zp\",\n  \"invoiceDate\": \"2026-02-21\",\n  \"invoiceAmount\": 15000,\n  \"irn\": \"abc123\",\n  \"irnStatus\": \"VALID\",\n  \"lineItems\": [\n    { \"description\": \"Widget A\", \"sku\": \"WA-01\", \"quantity\": 10, \"unitPrice\": 1500, \"total\": 15000 }\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/invoices/verify",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "invoices",
                "verify"
              ]
            }
          }
        },
        {
